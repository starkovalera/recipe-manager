APP_ENV=PROD
CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

# Required in PROD. Use a TLS-enabled managed PostgreSQL URL.
# SQS and S3 are the required target providers; their runtime adapters are implemented in later production iterations.
DATABASE_URL=
QUEUE_PROVIDER=SQS
STORAGE_PROVIDER=S3

# Required when QUEUE_PROVIDER=SQS. Queue URLs are configuration, not secrets.
AWS_REGION=
SQS_IMPORTS_QUEUE_URL=
SQS_EMBEDDINGS_QUEUE_URL=
SQS_ACCOUNT_DELETION_QUEUE_URL=
# Do not store AWS credentials here. boto3 uses the standard AWS credential chain.

# PREVIEW defaults:
# APP_ENV=PREVIEW
# QUEUE_PROVIDER=DRAMATIQ
# STORAGE_PROVIDER=LOCAL
# DATABASE_URL=postgresql+psycopg://recipe_manager:recipe_manager@127.0.0.1:5432/recipe_manager_preview
# REDIS_URL=redis://127.0.0.1:6379/0
# UPLOAD_DIR=./storage/preview/uploads

# Paste your OpenAI key in backend/.env, not in this example file.
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_RECIPE_MODEL=gpt-4.1-mini
OPENAI_VIDEO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_COVER_VALIDATION_MODEL=gpt-4.1-mini

MAX_IMPORT_IMAGES=10
MAX_IMPORT_TEXT_CHARS=1000
MAX_RECIPE_INGREDIENTS=50
MAX_RECIPE_INSTRUCTION_CHARS=1000
MAX_RECIPE_NOTE_CHARS=500
MAX_TAGS_PER_USER=50
RECIPE_LANGUAGE=ru
MAX_UPLOAD_BYTES=8388608
MAX_VIDEO_BYTES=67108864
MAX_IMPORT_VIDEOS=1
IMPORT_MIN_CONFIDENCE=0
IMPORT_WARN_CONFIDENCE=0.75
MAX_PARALLEL_IMPORTS_PER_CLIENT=3
MAX_IMPORT_ATTEMPTS=3
IMPORT_TASK_MAX_RETRIES=0
STALE_IMPORT_MINUTES=30
OUTBOX_RECONCILE_BATCH_SIZE=100

ENABLE_COVER_CANDIDATE_GUARD=false
MAX_COVER_FALLBACK_CANDIDATES=0

# Optional, needed later for real video processing.
FFMPEG_PATH=
FFPROBE_PATH=

# Clerk backend/provider configuration. Keep secret values only in the ignored backend/.env.
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
CLERK_API_URL=https://api.clerk.com
FRONTEND_INVITATION_URL=http://127.0.0.1:5173/sign-up
ACCOUNT_DELETION_TASK_MAX_RETRIES=3
# PREVIEW only: points to an ignored TOML file containing real Clerk development user ids.
PREVIEW_USERS_FILE=./config/preview-users.local.toml
