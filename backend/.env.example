APP_ENV=dev

# Local persistent dev storage.
# Leave these commented to use the defaults:
# DATABASE_URL=sqlite:///./storage/dev/app.db
# UPLOAD_DIR=./storage/dev/uploads

# Paste your OpenAI key in backend/.env, not in this example file.
OPENAI_API_KEY=
OPENAI_RECIPE_MODEL=gpt-4.1-mini
OPENAI_VIDEO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_COVER_VALIDATION_MODEL=gpt-4.1-mini

MAX_IMPORT_IMAGES=10
MAX_IMPORT_TEXT_CHARS=500
MAX_RECIPE_NOTE_CHARS=500
MAX_UPLOAD_BYTES=8388608
MAX_VIDEO_BYTES=67108864
MAX_IMPORT_VIDEOS=1
IMPORT_MIN_CONFIDENCE=0
IMPORT_WARN_CONFIDENCE=0.75
MAX_PARALLEL_IMPORTS_PER_CLIENT=1
STALE_IMPORT_MINUTES=30

ENABLE_COVER_CANDIDATE_GUARD=false
MAX_COVER_FALLBACK_CANDIDATES=0

# Optional, needed later for real video processing.
FFMPEG_PATH=
FFPROBE_PATH=
